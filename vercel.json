{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api(?:/.*)?$",
      "status": 404
    },
    {
      "src": "^/.*\\.(?:avif|css|gif|ico|jpe?g|js|json|map|mjs|png|svg|txt|webmanifest|webp|woff2?|xml)$",
      "status": 404
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
