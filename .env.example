# Admin auth.
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Media uploads on Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Runtime content storage.
# Use a Marketplace Postgres integration on Vercel (for example Neon) and expose DATABASE_URL.
DATABASE_URL=

# Exposed to the frontend bundle via vite.config.ts for client-side imgproxy signing.
IMGPROXY_BASE=https://imgproxy.thewisemonkey.co.uk
IMGPROXY_KEY=
IMGPROXY_SALT=
IMGPROXY_SIGNATURE_SIZE=32
